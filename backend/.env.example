PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/mdcat_lms
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345
JWT_EXPIRE=7d
GOOGLE_CLIENT_ID=
ALLOW_DEBUG_OTP=false
SMTP_SERVICE=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="MDCAT LMS <no-reply@mdcat-lms.com>"
# Recommended for production (works even if SMTP ports are blocked by your host):
# Create an API key at https://resend.com and verify a sending domain, then set:
RESEND_API_KEY=
RESEND_TIMEOUT_MS=10000
# Alternative (no SMTP): Brevo (Sendinblue) HTTP API.
# Create an API key at https://app.brevo.com, then verify a sender email in Brevo.
BREVO_API_KEY=
BREVO_TIMEOUT_MS=10000
# If SMTP is not set and ALLOW_DEBUG_OTP=true in development, API returns debugOtp for testing.
