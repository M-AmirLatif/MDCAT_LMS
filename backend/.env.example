NODE_ENV=production
PORT=5000

# MongoDB Atlas SRV connection string. Replace <password> with the Atlas DB user password.
MONGO_URI=mongodb+srv://amirlatif2288_db_user:<password>@cluster0.ljm4hc2.mongodb.net/mdcat_lms?retryWrites=true&w=majority&appName=Cluster0

# Use a long random value in production. Do not commit the real value.
JWT_SECRET=replace-with-a-64-character-random-secret
JWT_EXPIRE=7d

# Comma-separated frontend origins allowed to call the API.
# Add your final Vercel production domain after Vercel deploys.
CORS_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# Google Identity Services client ID used by frontend and backend token verification.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Keep false in production. Only true for local debugging without email delivery.
ALLOW_DEBUG_OTP=false

# SMTP option. Gmail requires an App Password, not your normal Gmail password.
SMTP_SERVICE=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="MDCAT LMS <no-reply@mdcat-lms.com>"
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000

# Recommended production email option if SMTP ports are blocked by the host.
RESEND_API_KEY=
RESEND_TIMEOUT_MS=10000

# Alternative production email option.
BREVO_API_KEY=
BREVO_TIMEOUT_MS=10000
